{
  "info": {
    "name": "WebCBD API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/ecommerce/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ecommerce",
            "v1",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Auth - Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/ecommerce/v1/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ecommerce",
            "v1",
            "auth",
            "logout"
          ]
        }
      }
    },
    {
      "name": "Products - Get All",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/ecommerce/v1/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ecommerce",
            "v1",
            "products"
          ]
        }
      }
    },
    {
      "name": "Products - Create (Admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Noise Cancelling Headphones\",\n  \"category\": \"Electronics\",\n  \"price\": 129.99,\n  \"description\": \"Over-ear headphones with active noise cancellation\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/ecommerce/v1/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ecommerce",
            "v1",
            "products"
          ]
        }
      }
    },
    {
      "name": "Carts - Create",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/api/ecommerce/v1/carts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ecommerce",
            "v1",
            "carts"
          ]
        }
      }
    },
    {
      "name": "Carts - Get",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/ecommerce/v1/carts/{{cartId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ecommerce",
            "v1",
            "carts",
            "{{cartId}}"
          ]
        }
      }
    },
    {
      "name": "Carts - Add Product",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/api/ecommerce/v1/carts/{{cartId}}/products/{{productId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ecommerce",
            "v1",
            "carts",
            "{{cartId}}",
            "products",
            "{{productId}}"
          ]
        }
      }
    },
    {
      "name": "Carts - Remove Product",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/api/ecommerce/v1/carts/{{cartId}}/products/{{productId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ecommerce",
            "v1",
            "carts",
            "{{cartId}}",
            "products",
            "{{productId}}"
          ]
        }
      }
    },
    {
      "name": "Carts - Get All (Admin)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/ecommerce/v1/carts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ecommerce",
            "v1",
            "carts"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8082"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "cartId",
      "value": ""
    },
    {
      "key": "productId",
      "value": "1"
    }
  ]
}
