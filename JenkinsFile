def sonarRan = false

def runMvn(String args) {
  if (isUnix()) {
    sh "./mvnw ${args}"
  } else {
    bat "mvnw.cmd ${args}"
  }
}

pipeline {
  agent any
  options { timestamps(); skipDefaultCheckout(true) }
  tools { jdk 'Java@21' }
  triggers { pollSCM('H/2 * * * *') }


  environment {
    MAVEN_OPTS = "-Dmaven.repo.local=.m2/repository"
    SONARQUBE_RAN = "false"
  }

  stages {
    stage('Checkout') {
      steps { checkout scm }
    }

    stage('Build & Tests') {
      steps {
        script {
          runMvn("-B clean verify -Dspring.profiles.active=test")
        }
      }
    }

    stage('SonarQube Analysis') {
      steps {
        script {
          try {
            withSonarQubeEnv('LocalSonar') {
              runMvn("-B sonar:sonar -Dsonar.projectKey=com.mase.webcbd:WebCBD -Dsonar.projectName=WebCBD-1")
            }
            sonarRan = true
          } catch (Exception e) {
            echo "SonarQube plugin not installed; skipping SonarQube Analysis."
            sonarRan = false
          }
        }
      }
    }

    stage('Quality Gate') {
      when {
        expression { return sonarRan }
      }
      steps {
        script {
          try {
            timeout(time: 2, unit: 'MINUTES') {
              waitForQualityGate abortPipeline: true
            }
          } catch (Exception e) {
            echo "SonarQube plugin not installed; skipping quality gate."
          }
        }
      }
    }
  }
  
  
  

  post {
    always {
      junit testResults: '**/target/surefire-reports/*.xml, **/target/failsafe-reports/*.xml', allowEmptyResults: true
      archiveArtifacts artifacts: '**/target/*.jar, **/target/*.war', allowEmptyArchive: true

      script {
        if (fileExists('target/site/jacoco/index.html')) {
          publishHTML(target: [
            reportDir: 'target/site/jacoco',
            reportFiles: 'index.html',
            reportName: 'JaCoCo Code Coverage',
            keepAll: true,
            alwaysLinkToLastBuild: true,
            allowMissing: true
          ])
        } else {
          echo "JaCoCo report not found; skipping HTML publish."
        }
      }
    }
  }
}
