def runMvn(String args) {
  if (isUnix()) {
    sh "./mvnw ${args}"
  } else {
    bat "mvnw.cmd ${args}"
  }
}

pipeline {
  agent any
  options { timestamps(); skipDefaultCheckout(true) }
  tools { jdk 'Java@21' }
  triggers { pollSCM('H/5 * * * *') }

  parameters {
    booleanParam(name: 'RUN_IT', defaultValue: false, description: 'Run integration/Selenium tests (Failsafe)')
  }

  environment {
    MAVEN_OPTS = "-Dmaven.repo.local=.m2/repository"
    SONARQUBE_RAN = "false"
  }

  stages {
    stage('Checkout') {
      steps { checkout scm }
    }

    stage('Build & Tests') {
      steps {
        script {
          def baseArgs = "-B clean verify -Dspring.profiles.active=test"
          def itArgs = params.RUN_IT ? "-DskipITs=false" : "-DskipITs=true"
          runMvn("${baseArgs} ${itArgs}")
        }
      }
    }

    stage('Package') {
      steps {
        script {
          runMvn("-B -DskipTests package")
        }
      }
    }

    stage('SonarQube Analysis') {
      steps {
        script {
          def hasSonarEnv = steps.metaClass.respondsTo(steps, 'withSonarQubeEnv', String)
          if (hasSonarEnv) {
            steps.withSonarQubeEnv('LocalSonar') {
              runMvn("-B sonar:sonar -Dsonar.projectKey=com.mase.webcbd:WebCBD -Dsonar.projectName=WebCBD-1")
            }
            env.SONARQUBE_RAN = "true"
          } else {
            echo "SonarQube plugin not installed; skipping analysis."
          }
        }
      }
    }

    stage('Quality Gate') {
      when {
        expression { return env.SONARQUBE_RAN == "true" }
      }
      steps {
        script {
          def hasQualityGate = steps.metaClass.respondsTo(steps, 'waitForQualityGate', Map)
          if (hasQualityGate) {
            timeout(time: 10, unit: 'MINUTES') {
              waitForQualityGate abortPipeline: true
            }
          } else {
            echo "SonarQube plugin not installed; skipping quality gate."
          }
        }
      }
    }
  }

  post {
    always {
      junit testResults: '**/target/surefire-reports/*.xml, **/target/failsafe-reports/*.xml', allowEmptyResults: true
      archiveArtifacts artifacts: '**/target/*.jar, **/target/*.war', allowEmptyArchive: true

      script {
        if (fileExists('target/site/jacoco/index.html')) {
          publishHTML(target: [
            reportDir: 'target/site/jacoco',
            reportFiles: 'index.html',
            reportName: 'JaCoCo Code Coverage',
            keepAll: true,
            alwaysLinkToLastBuild: true,
            allowMissing: true
          ])
        } else {
          echo "JaCoCo report not found; skipping HTML publish."
        }
      }
    }
  }
}
